# Force LF line endings everywhere so the Linux VM always gets clean files,
# regardless of being edited/committed from Windows.
* text=auto eol=lf
*.py   text eol=lf
*.sh   text eol=lf
*.md   text eol=lf

# Treat these as binary (belt-and-suspenders; they're gitignored anyway)
*.zip  binary
*.pkl  binary
*.db   binary
