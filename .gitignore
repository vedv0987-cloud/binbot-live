# ──────────────────────────────────────────────────────────────────────────
# BinBot .gitignore — keeps SECRETS and LIVE STATE out of git.
# Critical side effect: because runtime state is ignored, `git pull` on the VM
# only ever updates .py code and NEVER touches bot_state.json / journals / models.
# That removes the "wipe state on deploy" footgun by design.
# ──────────────────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit ──
.env
.env.*
!.env.example
*.key
*.pem
*credentials*
*secret*

# ── Live runtime state (regenerated by the bot; must survive a git pull) ──
bot_state.json
bot_state.json.bak
bot_state.json.tmp.*
trade_history.json
equity_curve.json
coin_profiles.json
.feature_flags.json
kelly_history.json
selfhealer_state.json
heartbeat.txt

# Trade journals / telemetry (append-only logs)
*.jsonl
*.jsonl.*

# SQLite (the legacy journal.db + WAL/SHM sidecars)
*.db
*.db-wal
*.db-shm

# Trained ML models / scalers
*.pkl
*.joblib
.ml_cache/
catboost_info/

# Corruption backups + logs
*.corrupted_backup_*
*.log
*.log.*

# ── Build / packaging artifacts ──
BinBot_V*.zip
*.zip

# ── Python / tooling ──
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
*.egg-info/
.venv/
venv/

# ── OS / editor ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
