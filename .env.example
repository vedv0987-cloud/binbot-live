# BinBot environment variables — COPY to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed. On the VM these are loaded
# by systemd (EnvironmentFile=/home/ubuntu/binbot_live/.env).

# ── Binance (REQUIRED — mainnet, trading enabled) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Telegram alerts/commands (optional — enables TG if both set) ──
TG_BOT_TOKEN=
TG_CHAT_ID=

# ── Azure OpenAI news sentiment (optional) ──
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_MODEL=gpt-oss-120b

# ── HuggingFace inference (optional) ──
HF_API_TOKEN=

# ── External watchdog (watchdog.py via binbot-watchdog.timer) ──
# Heartbeat-restart always runs. The equity-floor kill switch is OPT-IN: set a hard
# absolute USD floor BELOW your normal equity (0/unset = disabled). Optional flatten.
WATCHDOG_FLOOR_USD=0
# WATCHDOG_STALE_SEC=300
# WATCHDOG_FLATTEN=0

# ── Optional feature flags ──
# BINBOT_ENABLE_LSTM=0
